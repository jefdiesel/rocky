# ======================
# Server Configuration
# ======================
PORT=3001
NODE_ENV=development

# ======================
# Supabase
# ======================
# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=
# Service role key — has full access, keep secret
SUPABASE_SERVICE_KEY=

# ======================
# Meta / Facebook App
# ======================
# Create an app at https://developers.facebook.com
# Leave blank to run in mock-data mode
META_APP_ID=
META_APP_SECRET=

# ======================
# OAuth / Session
# ======================
# Base URL for OAuth callback redirect (no trailing slash)
OAUTH_REDIRECT_BASE=http://localhost:3001
# Random string used to sign session tokens
SESSION_SECRET=change-me-to-a-random-string

# ======================
# Frontend
# ======================
# Allowed CORS origin for the Vite dev server
CLIENT_ORIGIN=http://localhost:5173
