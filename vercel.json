{
  "version": 2,
  "framework": null,
  "installCommand": "echo 'skip'",
  "buildCommand": "ls -la && npm install --prefix ./server && npm install --prefix ./client && cd client && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/health", "destination": "/api" },
    { "source": "/((?!api|health|assets|favicon).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    }
  }
}
